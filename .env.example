# QA Security Scanner - Environment Variables
# Copy this file to .env and adjust values as needed

# ZAP Configuration
# URL of the OWASP ZAP instance (Docker service name)
QA_SCANNER_ZAP_BASE_URL=http://zap:8080
# ZAP API key (leave empty if disabled)
QA_SCANNER_ZAP_API_KEY=

# CORS Configuration
# Comma-separated list of allowed origins
QA_SCANNER_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Scan Timeouts
QA_SCANNER_SCAN_TIMEOUT_SECONDS=600
QA_SCANNER_ZAP_SCAN_TIMEOUT_SECONDS=600
QA_SCANNER_ZAP_ACTIVE_SCAN_TIMEOUT_SECONDS=600
QA_SCANNER_NUCLEI_SCAN_TIMEOUT_SECONDS=120

# Nuclei Settings
QA_SCANNER_NUCLEI_RATE_LIMIT=150
QA_SCANNER_NUCLEI_TIMEOUT=10
QA_SCANNER_NUCLEI_SEVERITIES=["critical","high","medium","low"]
# Optional: custom template path
# QA_SCANNER_NUCLEI_TEMPLATES=/path/to/templates

# ZAP Scan Limits
QA_SCANNER_ZAP_MAX_DEPTH=3
# QA_SCANNER_ZAP_MAX_CHILDREN=  # Uncomment to limit crawl scope
QA_SCANNER_ZAP_THREAD_COUNT=10
